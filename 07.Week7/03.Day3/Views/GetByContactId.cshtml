<h1>Contact Details</h1>
<hr />

<table border="1" cellpadding="10">
    <tr><th>ContactId</th><td>@Model.ContactId</td></tr>
    <tr><th>FirstName</th><td>@Model.FirstName</td></tr>
    <tr><th>LastName</th><td>@Model.LastName</td></tr>
    <tr><th>CompanyName</th><td>@Model.CompanyName</td></tr>
    <tr><th>EmailId</th><td>@Model.EmailId</td></tr>
    <tr><th>MobileNo</th><td>@Model.MobileNo</td></tr>
    <tr><th>Designation</th><td>@Model.Designation</td></tr>
</table>

<br />
<a asp-action="GetAll">Back</a>