@model WebApplication2.Models.Movie

<h1>Delete Movie</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<table class="table table-bordered">
    <tr>
        <th>Title</th>
        <td>@Model.Title</td>
    </tr>
    <tr>
        <th>Genre</th>
        <td>@Model.Genre</td>
    </tr>
    <tr>
        <th>Release Date</th>
        <td>@Model.ReleaseDate.ToShortDateString()</td>
    </tr>
    <tr>
        <th>Price</th>
        <td>@Model.Price</td>
    </tr>
    <tr>
        <th>Rating</th>
        <td>@Model.Rating</td>
    </tr>
</table>

<form asp-action="Delete" method="post">
   

    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="GetAll" class="btn btn-secondary">Cancel</a>
</form>
