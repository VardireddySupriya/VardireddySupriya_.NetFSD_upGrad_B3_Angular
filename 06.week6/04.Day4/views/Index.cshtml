@using WebApplication1.Models
@model List<Product>
<h1 class="display-5">this is products page</h1>
<div>
    <table border="1" cellpadding="10" cellspacing="0">
    <thead >
        <tr>
            <th>ProductId</th>
            <th>ProductName</th>
            <th>Price</th>
            <th>Category</th>
            <th>quantity</th>
        </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>@item.Price</td>
                    <td>@item.Category</td>
                    <td>@item.quantity</td>
                </tr>
                
            }
        </tbody>
    
    </table>
</div>




