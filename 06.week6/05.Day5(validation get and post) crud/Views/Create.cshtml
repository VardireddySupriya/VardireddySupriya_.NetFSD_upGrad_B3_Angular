@model Product
<h1>Create Product</h1>
<hr/>
<form asp-action="Create" method="post">
    <div class="form-group">
    <label asp-for="ProductId" class="Form-Control"></label>
    <input asp-for="ProductId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="ProductName" class="Form-Control"></label>
        <input asp-for="ProductName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Price" class="Form-Control"></label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Category" class="Form-Control"></label>
        <input asp-for="Category" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="quantity" class="Form-Control"></label>
        <input asp-for="quantity" class="form-control"  />
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
